# OS / editor cruft
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
*.egg-info/

# Node (report tooling)
node_modules/
report/node_modules/

# Personal local Claude settings + runtime state + handoff notes (machine-specific, local-only)
.claude/

# Annotated learning copy (regenerable teaching snapshot; not source of truth)
annotated-codebase/

# Default sq-generate/tri-generate output (out/<uid>/ bundles) -- regenerable, not source of truth
out/

# sq-generate bundle dirs written to a custom --out instead of out/, plus the scratch dir the report
# renderers use as a montage sink. Same idea as out/: regenerable, not source of truth. Kept on disk
# rather than deleted because square/render/report_examples.py reads SPECIFIC uids out of the g_*
# dirs for its figure captions, and regenerating them does NOT reproduce those uids -- a uid hashes
# the canonical hash, which S3 rewrote for every non-square grid (g_2p1_6x4/e194f4a50fe6 ->
# 0728f7a454d5). report_examples.py also RECREATES scratch_examples/ on every run (makedirs), so
# deleting it is not enough to keep `git status` clean.
g_111_*/
g_2p1_*/
scratch2s/
scratch_examples/

# Oracle acceptance-run logs (scripts/phystest check, file-redirected -- never a PIPE). Transient
# run artifacts; the verdict that matters is recorded in docs/SESSIONS.md, not here.
/oracle_run*

# Local-only working dirs: kept on disk, untracked (git rm --cached'd). Notes, archived
# research, the write-up and generated results (SQLite DB lives here) live locally and are not part
# of the shared tree. (annotated-codebase/ above is the same idea.)
deprecated/
report/
results/

# The repo-root tests/ holds only local analysis scripts. LEADING SLASH IS LOAD-BEARING: a bare
# `tests/` has no slash, so git matches it against a directory named `tests` at ANY depth -- which
# silently swallowed the tracked square/tests/ and triangle/tests/ suites. `/tests/` anchors the
# rule to the repo root. Anchoring, not a `!square/tests/` negation: per the docs/ note below, git
# cannot re-include a file whose parent dir is excluded, so a negation here would be inert.
/tests/

# docs/ is local-only EXCEPT the shared execution plan. Note the pattern: git cannot re-include a
# file whose parent dir is excluded, so this must ignore docs/* (contents) rather than docs/ (the
# dir) for the negation below to take effect.
docs/*
!docs/SESSIONS.md
