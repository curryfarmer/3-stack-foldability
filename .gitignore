# OS / editor cruft
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Node (report tooling)
node_modules/
report/node_modules/

# Personal local Claude settings + runtime state + handoff notes (machine-specific, local-only)
.claude/

# tri scan logs
py/tri/_*.log

# Annotated learning copy (regenerable teaching snapshot; not source of truth)
annotated-codebase/

# SQLite pattern DB (write-master) + WAL/SHM sidecars. JSON export (store.export_json) is the
# committed/diffable archival snapshot; the binary DB is regenerable via migrate_to_sqlite + generate.
results/folddb.sqlite3
results/folddb.sqlite3-wal
results/folddb.sqlite3-shm
# Scratch/test DB (the --test flag) + its sidecars: throwaway, never committed.
results/folddb.test.sqlite3
results/folddb.test.sqlite3-wal
results/folddb.test.sqlite3-shm

# Local-only working dirs: kept on disk, untracked (git rm --cached'd). Notes, archived
# research, the write-up, generated results (SQLite DB lives here), and the test suite all
# live locally and are not part of the shared tree. (annotated-codebase/ above is the same idea.)
deprecated/
docs/
report/
results/
tests/
