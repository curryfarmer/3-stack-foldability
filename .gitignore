# OS / editor cruft
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
*.egg-info/

# Node (report tooling)
node_modules/
report/node_modules/

# Personal local Claude settings + runtime state + handoff notes (machine-specific, local-only)
.claude/

# Annotated learning copy (regenerable teaching snapshot; not source of truth)
annotated-codebase/

# Default sq-generate/tri-generate output (out/<uid>/ bundles) -- regenerable, not source of truth
out/

# Local-only working dirs: kept on disk, untracked (git rm --cached'd). Notes, archived
# research, the write-up, generated results (SQLite DB lives here), and the test suite all
# live locally and are not part of the shared tree. (annotated-codebase/ above is the same idea.)
deprecated/
report/
results/
tests/

# docs/ is local-only EXCEPT the shared execution plan. Note the pattern: git cannot re-include a
# file whose parent dir is excluded, so this must ignore docs/* (contents) rather than docs/ (the
# dir) for the negation below to take effect.
docs/*
!docs/SESSIONS.md
